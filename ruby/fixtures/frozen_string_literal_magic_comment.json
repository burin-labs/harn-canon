        }
      ]
    },
    {
      "name": "allows_magic_comment_after_shebang",
      "expect": "Allow",
      "files": [
        {
          "path": "app/models/invoice.rb",
          "text": "#!/usr/bin/env ruby\n# frozen_string_literal: true\n\nclass Invoice\n  CURRENCY = \"USD\"\nend\n"
        }
      ]
    }
  ]
}
