          "path": "Dockerfile",
          "text": "FROM node\nWORKDIR /app\nCOPY . .\nRUN npm ci\nCMD [\"node\", \"server.js\"]\n"
        }
      ]
    },
    {
      "name": "blocks_missing_tag_with_from_flag",
